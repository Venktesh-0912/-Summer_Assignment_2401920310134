class Solution:
    def checkInclusion(self, s1: str, s2: str) -> bool:
        if len(s1) > len(s2):
            return False
        for i in range(len(s2) - len(s1) + 1):
            part = s2[i:i + len(s1)]
            if sorted(part) == sorted(s1):
                return True
        return False
